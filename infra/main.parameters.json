{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "aiProjectEndpoint": {
      "value": "${AZURE_AI_PROJECT_ENDPOINT=}"
    },
    "aiModelDeploymentName": {
      "value": "${AZURE_AI_MODEL_DEPLOYMENT_NAME=}"
    },
    "foundryModelName": {
      "value": "${AZURE_AI_FOUNDRY_MODEL_NAME=gpt-5.4}"
    },
    "foundryModelVersion": {
      "value": "${AZURE_AI_FOUNDRY_MODEL_VERSION=2026-03-05}"
    },
    "foundryModelSkuName": {
      "value": "${AZURE_AI_FOUNDRY_MODEL_SKU=GlobalStandard}"
    },
    "foundryModelCapacity": {
      "value": "${AZURE_AI_FOUNDRY_MODEL_CAPACITY=10}"
    },
    "aiFoundryAccountName": {
      "value": "${AZURE_AI_FOUNDRY_ACCOUNT_NAME=}"
    },
    "aiFoundryResourceGroup": {
      "value": "${AZURE_AI_FOUNDRY_RESOURCE_GROUP=}"
    },
    "aribaUseMock": {
      "value": "${ARIBA_USE_MOCK=true}"
    },
    "aribaAppId": {
      "value": "${ARIBA_APP_ID=}"
    },
    "aribaClientId": {
      "value": "${ARIBA_CLIENT_ID=}"
    },
    "aribaClientSecret": {
      "value": "${ARIBA_CLIENT_SECRET=}"
    },
    "aribaRealm": {
      "value": "${ARIBA_REALM=}"
    }
  }
}

