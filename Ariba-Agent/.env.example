# URL do MCP Ariba (ex.: http://ariba-mcp-xxx.brazilsouth.azurecontainer.io:8000/mcp/)
ARIBA_MCP_URL=http://localhost:8000/mcp/

# Microsoft Foundry / Azure AI project
# Endpoint do projeto Foundry (em "Project details" no portal)
AZURE_AI_PROJECT_ENDPOINT=https://<seu-recurso>.services.ai.azure.com/api/projects/<seu-projeto>
# Nome do Agent no Foundry (obrigatorio)
AZURE_AI_AGENT_NAME=ariba-agent
# Nome do deployment de modelo (nao o nome do modelo base)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4
# Opcional: fixa a versao do agent. Se vazio, usa a ultima versao ou cria a primeira.
AZURE_AI_AGENT_VERSION=

# Flask
FLASK_SECRET=troque-isto
HOST=0.0.0.0
PORT=5000
